{
  "name": "pi-package-mono",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo of personal pi coding-agent packages.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "pi": {
    "extensions": [
      "./packages/pi-web-search/src/index.ts",
      "./packages/pi-subagent/src/index.ts"
    ]
  },
  "scripts": {
    "test": "npm run test --workspaces --if-present"
  }
}
