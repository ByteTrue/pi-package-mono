{
  "name": "@bytetrue/pi-web-search",
  "version": "0.1.2",
  "description": "Pi extension: web_search + web_fetch with zero-config Exa MCP free search, keyless Bing, self-hosted SearXNG, and pluggable providers (Bocha, Tavily, Exa, Brave, Jina, Firecrawl).",
  "keywords": [
    "pi-package",
    "pi-extension",
    "web-search",
    "web-fetch",
    "search",
    "fetch",
    "tavily",
    "exa",
    "brave",
    "jina",
    "firecrawl",
    "ai",
    "llm",
    "agent"
  ],
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "byte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ByteTrue/pi-package-mono.git",
    "directory": "packages/pi-web-search"
  },
  "files": [
    "src/**",
    "!src/**/*.test.ts",
    "!src/**/__fixtures__/**",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:e2e": "vitest run src/live.e2e.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "dependencies": {
    "undici": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
