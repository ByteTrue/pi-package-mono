{
  "name": "@byte/pi-subagent",
  "version": "0.1.0",
  "description": "Pi extension: Claude Code-style subagents. Delegate tasks to isolated, per-agent provider/model-configurable specialists (general-purpose, explore, plan) defined as Markdown files, driven entirely through tools (no TUI required).",
  "keywords": [
    "pi-package",
    "pi-extension",
    "subagent",
    "agent",
    "task",
    "delegation",
    "orchestration",
    "claude-code",
    "ai",
    "llm"
  ],
  "type": "module",
  "license": "MIT",
  "author": "byte",
  "files": [
    "src/**",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
