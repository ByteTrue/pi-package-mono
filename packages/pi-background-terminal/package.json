{
  "name": "@bytetrue/pi-background-terminal",
  "version": "0.1.0",
  "description": "Pi extension for OpenCode-style background PTY sessions, tools, and web monitor.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pty",
    "terminal",
    "background-process",
    "interactive",
    "web-monitor"
  ],
  "type": "module",
  "license": "MIT",
  "author": "byte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ByteTrue/pi-package-mono.git",
    "directory": "packages/pi-background-terminal"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build:web": "node src/web/build.mjs",
    "prepack": "npm run build:web",
    "test": "npm run build:web && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lydell/node-pty": "1.2.0-beta.12",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.79.10",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "esbuild": "^0.27.7",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
